{
	"name": "reeweb",
	"project-type": "template",
	"version": "26.07.85",
	"private": false,
	"license": "MIT",
	"description": "Static site generator with .ree templates and multi-language support",
	"sponsor": {
		"url": "https://github.com/sponsors/alesvaupotic"
	},
	"author": {
		"name": "Aleš Vaupotič",
		"email": "ales@reepolee.com",
		"url": "https://github.com/alesvaupotic/"
	},
	"contributors": [
		{
			"name": "Gal Jakič",
			"url": "https://github.com/morpheus7CS"
		}
	],
	"type": "module",
	"scripts": {
		"dev": "conc -n img,tw,dev -c magenta,yellow,blue \"bun run prepare:images\" \"bun css:watch\" \"bun development\"",
		"development": "bun --hot --no-clear-screen scripts/dev.ts",
		"prepare:images": "bun scripts/prepare_images.ts",
		"css:build": "tailwindcss -i ./src/css/style.css -o ./src/public/css/style.min.css --minify",
		"css:watch": "tailwindcss -i ./src/css/style.css -o ./src/public/css/style.min.css --minify --watch",
		"ssg": "bun run prepare:images && bun css:build && bun scripts/ssg.ts --public ./src/public --dist ./dist && bun run sitemap && bun run rss && bun run ssg:search",
		"ssg:print-url": "bun scripts/ssg.ts --print-url",
		"ssg:search": "bun scripts/generate_search_index.ts --public ./src/public --dist ./dist",
		"mcp": "bun scripts/mcp/index.ts",
		"rss": "bun scripts/generate_rss.ts --public ./src/public --dist ./dist",
		"sitemap": "bun scripts/generate_sitemap.ts --public ./src/public --dist ./dist",
		"git:commit-push": "bun scripts/git_commit_push.ts",
		"cf:share": "wrangler dev --tunnel",
		"cf:deploy": "wrangler deploy && bun scripts/print_site_url.ts",
		"release": "reettier && bun run scripts/release.ts",
		"format": "reettier",
		"preview": "bun scripts/preview.ts",
		"get:tw": "bun add -g @tailwindcss/cli@4.3.3",
		"get:conc": "bun add -g concurrently@10.0.3",
		"get:reettier": "bun scripts/cli.ts reettier",
		"get:reesql": "bun scripts/cli.ts reesql",
		"get:zod": "mkdir -p vendor && curl -fsSL https://cdn.jsdelivr.net/npm/zod@4.4.3/+esm -o vendor/zod.min.js",
		"get:hljs": "mkdir -p vendor && curl -fsSL https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.11.1/highlight.min.js -o vendor/highlight.min.js && curl -fsSL https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.11.1/styles/atom-one-dark.min.css -o vendor/highlight-atom-one-dark.min.css",
		"get:pre": "bun get:zod && bun get:hljs && bun get:conc && bun get:reettier && bun get:reesql",
		"reeweb:install": "bun scripts/install.ts && bun get:pre",
		"vendor:check": "bun scripts/vendor_check.ts",
		"engine:check": "bun scripts/engine_drift_check.ts",
		"reconcile": "bun scripts/reconcile.ts",
		"git:releases": "bun scripts/git_releases.ts ../releases",
		"remove:demo": "bun scripts/remove_demo_content.ts"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "5.20260717.1",
		"@types/bun": "1.3.14",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.3",
		"typescript": "7.0.2"
	}
}
