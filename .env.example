# Environment variables for the dev server and static site generation.

# Required: full site URL, used for canonical/hreflang links and feeds/sitemap.
SITE_URL=https://example.com

# Required: base URL path the site is served from ("/" for a domain root).
BASE_URL=/

# Required: local server port (dev server + preview server). CLI --port overrides.
PORT=3000

# Publisher dashboard and Cloudflare candidate preview ports.
PUBLISHER_PORT=3011
PUBLISHER_PREVIEW_PORT=3012

# Only clean commits on this branch are eligible for release rendering.
PUBLISHER_BRANCH=main

# Required: sub-directory under the public dir that holds blog posts (for RSS/JSON feeds).
BLOG_DIR=blog

# Dev inspector: which IDE to open on click. One of: vscode, zed, nvim, sublime, idea.
OPEN_IDE=vscode

# Tailwind CSS v4 standalone CLI (if not globally installed)
# TAILWIND_BIN=./node_modules/.bin/tailwindcss

# reepolee read API base URL (required when any load_template_data() calls fetch_collection/fetch_record)
# Start reepolee in agent mode: bun run agent (set AGENT_SERVER_PORT in reepolee's .env, e.g. 2500)
# Then set this to http://localhost:<AGENT_SERVER_PORT>
REEPOLEE_API_URL=http://localhost:2500
